# Server
PORT=3001
NODE_ENV=development

# Frontend URLs (CORS)
FRONTEND_URL=http://localhost:5173
FRONTEND_URL_PROD=https://ownly-weld.vercel.app

# Blockchain - Polygon Amoy Testnet
RPC_URL=https://rpc-amoy.polygon.technology
CHAIN_ID=80002

# Smart Contracts
BATCH_PROCESSOR_ADDRESS=0x65ac8030675592aeB9E93994ac35bA48282E98CA
CREDENTIAL_REGISTRY_ADDRESS=0x193f9ad4b82e7211D885eFb913F1741892F430fE
VERIFIER_CONTRACT_ADDRESS=0x7368efd0B81F675B3B392e8534d8A74FA0b0D2A2

# Issuer Wallet
ISSUER_PRIVATE_KEY=your_private_key_here

# Sumsub KYC
SUMSUB_APP_TOKEN=sbx:your_app_token_here
SUMSUB_SECRET_KEY=your_secret_key_here
SUMSUB_BASE_URL=https://api.sumsub.com
SUMSUB_LEVEL_NAME=basic-kyc-level

# Supabase Database
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# Webhook Security
WEBHOOK_SECRET=generate_random_string_here
